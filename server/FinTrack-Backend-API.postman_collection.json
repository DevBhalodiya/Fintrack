{
  "info": {
    "_postman_id": "fintrack-backend-api",
    "name": "FinTrack Backend API",
    "description": "Personal Finance Tracker Backend API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "register"]
            },
            "description": "Register a new user account"
          },
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "login"]
            },
            "description": "Login with email and password"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Get All Transactions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text",
                "description": "Replace {{token}} with your JWT token from login response"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/transactions",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "transactions"]
            },
            "description": "Get all transactions for the authenticated user"
          },
          "response": []
        },
        {
          "name": "Get Transaction Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/transactions/summary",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "transactions", "summary"]
            },
            "description": "Get transaction summary (total income, expense, and balance)"
          },
          "response": []
        },
        {
          "name": "Create Transaction (Income)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"income\",\n  \"category\": \"Salary\",\n  \"amount\": 5000,\n  \"description\": \"Monthly salary\",\n  \"date\": \"2024-01-15\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/transactions",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "transactions"]
            },
            "description": "Create a new income transaction"
          },
          "response": []
        },
        {
          "name": "Create Transaction (Expense)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"expense\",\n  \"category\": \"Groceries\",\n  \"amount\": 150,\n  \"description\": \"Weekly groceries\",\n  \"date\": \"2024-01-16\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/transactions",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "transactions"]
            },
            "description": "Create a new expense transaction"
          },
          "response": []
        },
        {
          "name": "Update Transaction",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 200,\n  \"description\": \"Updated groceries expense\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/transactions/{{transaction_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "transactions", "{{transaction_id}}"]
            },
            "description": "Update an existing transaction. Replace {{transaction_id}} with the transaction ID"
          },
          "response": []
        },
        {
          "name": "Delete Transaction",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/transactions/{{transaction_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "transactions", "{{transaction_id}}"]
            },
            "description": "Delete a transaction. Replace {{transaction_id}} with the transaction ID"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/health",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["health"]
        },
        "description": "Check if the server is running"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "token",
      "value": "your_jwt_token_here",
      "type": "string"
    },
    {
      "key": "transaction_id",
      "value": "transaction_id_from_response",
      "type": "string"
    }
  ]
}
